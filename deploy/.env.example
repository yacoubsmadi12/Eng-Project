# ============================================================
# Z Route Master — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/zroute

# Session secret — use a long random string (min 32 chars)
SESSION_SECRET=change-this-to-a-very-long-random-secret-string

# API server port
PORT=8080

# Frontend base path (keep as / for root deployment)
BASE_PATH=/
